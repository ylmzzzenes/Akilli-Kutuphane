@model IReadOnlyList<BookCardDto>
@{
    ViewData["Title"] = "Favorilerim";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Favori Kitaplarım</h2>
    <a class="btn btn-outline-primary btn-sm" asp-controller="Books" asp-action="Index">Yeni Kitap Ara</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        Henüz favori kitabın yok. <a asp-controller="Books" asp-action="Index">Kitap keşfetmeye başla</a>.
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var book in Model)
        {
            <div class="col-12 col-sm-6 col-lg-4">
                <div class="book-card card border-0 shadow-sm h-100">
                    <img class="card-img-top book-cover" src="@(book.CoverImageUrl ?? "https://placehold.co/600x400/e9ecef/6c757d?text=No+Cover")" alt="@book.Title" />
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@book.Title</h5>
                        <p class="card-text text-body-secondary small">@book.Authors</p>
                        <p class="small mb-3">
                            <span class="badge text-bg-warning-subtle">Ortalama: @book.AverageRating.ToString("0.0")</span>
                        </p>
                        <div class="mt-auto">
                            <a class="btn btn-outline-primary btn-sm btn-animated me-2"
                               asp-controller="Books"
                               asp-action="Details"
                               asp-route-id="@book.ExternalId"
                               asp-route-returnUrl="@Context.Request.Path">
                                Detay
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
