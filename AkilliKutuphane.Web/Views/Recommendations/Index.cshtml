@model IReadOnlyList<AiRecommendationDto>
@{
    ViewData["Title"] = "AI Önerilerim";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="mb-1">AI Kitap Önerileri</h2>
        <p class="text-body-secondary mb-0">Favori ve puan geçmişine göre kişiselleştirilmiş liste.</p>
    </div>
    <a class="btn btn-outline-primary btn-sm" asp-controller="Books" asp-action="Index">Yeni Kitap Ara</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">Henüz öneri üretilemedi. Birkaç kitabı favorileyip puanladıktan sonra tekrar dene.</div>
}
else
{
    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-12 col-sm-6 col-lg-4">
                <div class="book-card card border-0 shadow-sm h-100">
                    <img class="card-img-top book-cover" src="@(item.Book.CoverImageUrl ?? "https://placehold.co/600x400/e9ecef/6c757d?text=No+Cover")" alt="@item.Book.Title" />
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@item.Book.Title</h5>
                        <p class="card-text text-body-secondary small mb-2">@item.Book.Authors</p>
                        <p class="small mb-1">
                            <span class="badge text-bg-primary-subtle">AI Güven: @(item.ConfidenceScore * 100)%</span>
                            <span class="badge text-bg-warning-subtle">Ortalama: @item.Book.AverageRating.ToString("0.0")</span>
                        </p>
                        <p class="small text-body-secondary mb-3"><i class="bi bi-stars me-1"></i>@item.Reason</p>
                        <div class="mt-auto">
                            <a class="btn btn-outline-primary btn-sm btn-animated"
                               asp-controller="Books"
                               asp-action="Details"
                               asp-route-id="@item.Book.ExternalId"
                               asp-route-returnUrl="@Context.Request.Path">
                                Detay
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
