@model BookListPageViewModel
@{
    ViewData["Title"] = "Kitaplar";
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Kitap Keşfet</h2>
</div>

<form method="get" class="card border-0 shadow-sm p-3 mb-4">
    <div class="row g-2">
        <div class="col-md-5">
            <input class="form-control" type="text" name="query" value="@Model.Query" placeholder="Kitap adı veya anahtar kelime" />
        </div>
        <div class="col-md-5">
            <input class="form-control" type="text" name="author" value="@Model.Author" placeholder="Yazar" />
        </div>
        <div class="col-md-2 d-grid">
            <button class="btn btn-primary btn-animated" type="submit">
                <i class="bi bi-funnel me-1"></i>Filtrele
            </button>
        </div>
    </div>
</form>

<div class="row g-4">
    @foreach (var book in Model.Result.Items)
    {
        <div class="col-12 col-sm-6 col-lg-4">
            <div class="book-card card border-0 shadow-sm h-100">
                <img class="card-img-top book-cover" src="@(book.CoverImageUrl ?? "https://placehold.co/600x400/e9ecef/6c757d?text=No+Cover")" alt="@book.Title" />
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">@book.Title</h5>
                    <p class="card-text text-body-secondary small mb-2">@book.Authors</p>
                    <p class="small mb-3">
                        <span class="badge text-bg-light">Yıl: @(book.FirstPublishYear?.ToString() ?? "Bilinmiyor")</span>
                        <span class="badge text-bg-warning-subtle">Ortalama: @book.AverageRating.ToString("0.0")</span>
                    </p>
                    <div class="mt-auto d-flex gap-2">
                        <a class="btn btn-outline-primary btn-sm flex-fill btn-animated"
                           asp-controller="Books"
                           asp-action="Details"
                           asp-route-id="@book.ExternalId"
                           asp-route-returnUrl="@returnUrl">
                            Detay
                        </a>
                        @if (User.Identity?.IsAuthenticated ?? false)
                        {
                            <form asp-controller="Books" asp-action="ToggleFavorite" method="post" class="m-0">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="externalId" value="@book.ExternalId" />
                                <input type="hidden" name="isFavorite" value="@(book.IsFavorite ? "true" : "false")" />
                                <input type="hidden" name="returnUrl" value="@returnUrl" />
                                <button type="submit" class="btn btn-sm @(book.IsFavorite ? "btn-danger" : "btn-outline-danger") btn-animated">
                                    <i class="bi @(book.IsFavorite ? "bi-heart-fill" : "bi-heart")"></i>
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Result.Items.Any())
{
    <div class="alert alert-info mt-4">Sonuç bulunamadı. Farklı bir arama deneyin.</div>
}

@if (Model.Result.TotalPages > 1)
{
    <nav class="mt-4" aria-label="Sayfalama">
        <ul class="pagination justify-content-center">
            @for (var i = 1; i <= Model.Result.TotalPages; i++)
            {
                <li class="page-item @(i == Model.Result.CurrentPage ? "active" : string.Empty)">
                    <a class="page-link" asp-action="Index" asp-route-query="@Model.Query" asp-route-author="@Model.Author" asp-route-page="@i">@i</a>
                </li>
            }
        </ul>
    </nav>
}
